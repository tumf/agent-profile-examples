{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "instructions": [
    "./../prompts/reviewer.md"
  ],
  "permission": {
    "edit": "deny",
    "bash": {
      "*": "allow",
      "git push": "deny",
      "git commit": "deny",
      "git rebase": "deny"
    },
    "webfetch": "allow",
    "doom_loop": "allow",
    "external_directory": "ask"
  },
  "tools": {
    "playwright": false
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": false
    }
  }
}