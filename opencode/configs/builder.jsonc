{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "instructions": [
    "./../prompts/builder.md"
  ],
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "allow",
      "git push": "ask",
      "git commit": "ask",
      "git rebase": "ask"
    },
    "webfetch": "allow",
    "doom_loop": "allow",
    "external_directory": "ask"
  },
  "tools": {
    "playwright": false
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": false
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": false
    }
  }
}